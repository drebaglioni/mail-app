# Local-only env vars — NEVER commit `.env.local` itself.
# Copy this file to `.env.local` and fill in the values.
#
# `.env.local` is gitignored and lives only on the developer's machine.
# CI never has access to any of these.

# ---- Anthropic API (optional legacy local checks) ----
# Used only by legacy local scripts that call Claude directly, such as
# scripts/agentic-verify.mjs, tests/evals/feature-evals.ts, and older spike
# scripts. The default app/eval path uses Codex/OpenAI and does not require
# this key.
ANTHROPIC_API_KEY=

# ---- Gmail OAuth for the dedicated test account ----
# Used by: scripts/seed-test-inbox.mjs, tests/real-gmail/* (when implemented).
# These authenticate as the dedicated test account — NEVER the user's real
# inbox.
#
# To obtain a refresh token: run `node scripts/seed-test-inbox.mjs` once
# with EXOEMAILTEST_EMAIL, EXOEMAILTEST_CLIENT_ID, and EXOEMAILTEST_CLIENT_SECRET
# set but the refresh token blank. The script prints a consent URL and
# auto-persists the resulting refresh token here.
#
# The OAuth client itself can be the same one used for the app dev flow,
# as long as the test account is added as a test user on the OAuth
# consent screen.
EXOEMAILTEST_EMAIL=
EXOEMAILTEST_CLIENT_ID=
EXOEMAILTEST_CLIENT_SECRET=
EXOEMAILTEST_REFRESH_TOKEN=
